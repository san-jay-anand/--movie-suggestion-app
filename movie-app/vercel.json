{
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/build",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/api/(.*)",
      "destination": "https://your-railway-backend-url.up.railway.app/api/$1"
    },
    {
      "src": "^/(?!api).*$",
      "destination": "/index.html"
    }
  ]
}
